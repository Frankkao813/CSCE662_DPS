{
  "version": "2.0.0",
  "tasks": [
    /* ---------- COORDINATOR ---------- */
    {
      "label": "Coordinator",
      "type": "shell",
      "command": "echo \"Cleaning up old semaphores...\" && rm -f /dev/shm/sem.* && echo \"STARTING COORDINATOR (p=9000)\" && ./coordinator -p 9000",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },

    /* ---------- TSD PROCESSES: first batch ---------- */
    {
      "label": "TSD c1 s1",
      "type": "shell",
      "command": "sleep 2 && echo \"STARTING TSD c1 s1 (p=10000)\" && ./tsd -c 1 -s 1 -h localhost -k 9000 -p 10000",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "TSD c2 s1",
      "type": "shell",
      "command": "sleep 2 && echo \"STARTING TSD c2 s1 (p=20000)\" && ./tsd -c 2 -s 1 -h localhost -k 9000 -p 20000",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "TSD c3 s1",
      "type": "shell",
      "command": "sleep 2 && echo \"STARTING TSD c3 s1 (p=30000)\" && ./tsd -c 3 -s 1 -h localhost -k 9000 -p 30000",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },

    /* ---------- TSD PROCESSES: second batch ---------- */
