    {
      "label": "TSC u3",
      "type": "shell",
      "command": "sleep 50 && echo \"START CLIENT u3\" && ./tsc -h localhost -k 9000 -u 3",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },

    /* ---------- MASTER TASK ---------- */
    {
      "label": "Start ALL (each in its own terminal)",
      "type": "shell",
      "command": "echo Starting all SNS processes in separate terminals...",
      "dependsOn": [
        "Coordinator",
        "TSD c1 s1",
        "TSD c2 s1",
        "TSD c3 s1",
        "TSD c1 s2",
        "TSD c2 s2",
        "TSD c3 s2",
        "Synchronizer 1",
        "Synchronizer 2",
        "Synchronizer 3",
        "Synchronizer 4",
        "Synchronizer 5",
        "Synchronizer 6",
        "TSC u1",
        "TSC u2",
        "TSC u3"
      ],
      "dependsOrder": "parallel",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
