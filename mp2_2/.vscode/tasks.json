      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "Synchronizer 3",
      "type": "shell",
      "command": "sleep 6 && echo \"STARTING SYNCHRONIZER 3 (p=9003)\" && ./synchronizer -h localhost -k 9000 -p 9003 -i 3",
