    /* ---------- TSC CLIENTS (run after 50 seconds) ---------- */
    {
      "label": "TSC u1",
      "type": "shell",
      "command": "sleep 50 && echo \"START CLIENT u1\" && ./tsc -h localhost -k 9000 -u 1",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "TSC u2",
      "type": "shell",
      "command": "sleep 50 && echo \"START CLIENT u2\" && ./tsc -h localhost -k 9000 -u 2",
      "options": { "cwd": "${workspaceFolder}" },
