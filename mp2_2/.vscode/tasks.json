      "label": "TSD c1 s2",
      "type": "shell",
      "command": "sleep 3 && echo \"STARTING TSD c1 s2 (p=10001)\" && ./tsd -c 1 -s 2 -h localhost -k 9000 -p 10001",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "TSD c2 s2",
      "type": "shell",
      "command": "sleep 3 && echo \"STARTING TSD c2 s2 (p=20001)\" && ./tsd -c 2 -s 2 -h localhost -k 9000 -p 20001",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "TSD c3 s2",
      "type": "shell",
      "command": "sleep 3 && echo \"STARTING TSD c3 s2 (p=30001)\" && ./tsd -c 3 -s 2 -h localhost -k 9000 -p 30001",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },

    /* ---------- SYNCHRONIZERS ---------- */
    {
      "label": "Synchronizer 1",
      "type": "shell",
      "command": "sleep 4 && echo \"STARTING SYNCHRONIZER 1 (p=9001)\" && ./synchronizer -h localhost -k 9000 -p 9001 -i 1",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "Synchronizer 2",
      "type": "shell",
      "command": "sleep 4 && echo \"STARTING SYNCHRONIZER 2 (p=9002)\" && ./synchronizer -h localhost -k 9000 -p 9002 -i 2",
