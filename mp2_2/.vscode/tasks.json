      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "Synchronizer 4",
      "type": "shell",
      "command": "sleep 6 && echo \"STARTING SYNCHRONIZER 4 (p=9004)\" && ./synchronizer -h localhost -k 9000 -p 9004 -i 4",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "Synchronizer 5",
      "type": "shell",
      "command": "sleep 6 && echo \"STARTING SYNCHRONIZER 5 (p=9005)\" && ./synchronizer -h localhost -k 9000 -p 9005 -i 5",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "Synchronizer 6",
      "type": "shell",
      "command": "sleep 6 && echo \"STARTING SYNCHRONIZER 6 (p=9006)\" && ./synchronizer -h localhost -k 9000 -p 9006 -i 6",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },

    /* ---------- CLIENTS ---------- */

    /* Fast clients from tasks0.json (for BASIC runs) */
    {
      "label": "TSC u1 (fast)",
      "type": "shell",
      "command": "sleep 6 && echo \"START CLIENT u1 (fast)\" && ./tsc -h localhost -k 9000 -u 1",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "TSC u4",
      "type": "shell",
      "command": "sleep 6 && echo \"START CLIENT u4\" && ./tsc -h localhost -k 9000 -u 4",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },

    /* Delayed clients from full cluster config */
    {
      "label": "TSC u1 (delayed)",
      "type": "shell",
      "command": "sleep 55 && echo \"START CLIENT u1 (delayed)\" && ./tsc -h localhost -k 9000 -u 1",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "TSC u2 (delayed)",
      "type": "shell",
      "command": "sleep 55 && echo \"START CLIENT u2 (delayed)\" && ./tsc -h localhost -k 9000 -u 2",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "TSC u3 (delayed)",
      "type": "shell",
      "command": "sleep 55 && echo \"START CLIENT u3 (delayed)\" && ./tsc -h localhost -k 9000 -u 3",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },

    /* ---------- MASTER TASKS ---------- */

    /* BASIC: coordinator + 2 TSDs + fast clients u1/u4 */
    {
      "label": "Start BASIC",
      "type": "shell",
      "command": "echo \"Starting BASIC setup...\"",
      "dependsOn": [
        "Coordinator",
        "TSD c1 s1",
        "TSD c1 s2",
        "TSC u1 (fast)",
        "TSC u4"
      ],
      "dependsOrder": "parallel",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },

    /* FULL CLUSTER: all TSDs, all synchronizers, delayed clients u1/u2/u3 */
    {
      "label": "Start FULL (each in its own terminal)",
      "type": "shell",
      "command": "echo \"Starting FULL SNS cluster in separate terminals...\"",
      "dependsOn": [
        "Coordinator",
        "TSD c1 s1",
        "TSD c2 s1",
        "TSD c3 s1",
        "TSD c1 s2",
        "TSD c2 s2",
        "TSD c3 s2",
        "Synchronizer 1",
        "Synchronizer 2",
        "Synchronizer 3",
        "Synchronizer 4",
        "Synchronizer 5",
        "Synchronizer 6",
        "TSC u1 (delayed)",
        "TSC u2 (delayed)",
        "TSC u3 (delayed)"
      ],
      "dependsOrder": "parallel",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
