      "problemMatcher": []
    },
    {
      "label": "Synchronizer 5",
      "type": "shell",
      "command": "sleep 4 && echo \"STARTING SYNCHRONIZER 5 (p=9005)\" && ./synchronizer -h localhost -k 9000 -p 9005 -i 5",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "Synchronizer 6",
      "type": "shell",
      "command": "sleep 4 && echo \"STARTING SYNCHRONIZER 6 (p=9006)\" && ./synchronizer -h localhost -k 9000 -p 9006 -i 6",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
